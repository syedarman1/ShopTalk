# ShopTalk Cloud — environment (multi-tenant service). Never commit real values.

# Public Shopify app credentials (from the ShopTalk Cloud app in the Dev Dashboard).
SHOPIFY_CLOUD_CLIENT_ID=
SHOPIFY_CLOUD_CLIENT_SECRET=

# Public base URL of THIS service once deployed (used to build the OAuth
# redirect_uri as <APP_URL>/auth/callback). Must match the app's Redirect URL.
SHOPIFY_CLOUD_APP_URL=https://your-cloud-host.example.com

# Scopes requested at install (comma-separated). read_all_orders is added later,
# after Shopify approves it.
SHOPIFY_CLOUD_SCOPES=read_orders,read_products,read_customers,read_inventory,read_locations,write_orders,write_inventory

# 32-byte key (64 hex chars) that encrypts each shop's token at rest.
# Generate: openssl rand -hex 32
CLOUD_ENC_KEY=

# SQLite path (put it on a persistent volume in production, e.g. /data/cloud.db).
CLOUD_DB=./data/cloud.db

PORT=4700
