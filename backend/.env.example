PORT=4000
# Single-quote the value: Node's --env-file treats an unquoted '#' as a comment
# and would truncate the JSON (e.g. a label like "Store #1").
# clientId = the Dev Dashboard app's API key; clientSecret = its secret (shpss_...).
SHOPIFY_STORES='[{"key":"main","label":"Main Store","shopDomain":"your-shop.myshopify.com","clientId":"your_api_key","clientSecret":"shpss_xxx","apiVersion":"2026-01"}]'
