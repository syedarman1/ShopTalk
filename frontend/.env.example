# Base URL of the backend (API + SSE + MCP). No trailing slash.
#   Local:      http://localhost:4000
#   Production: https://your-backend.example.com
NEXT_PUBLIC_API_BASE=http://localhost:4000

# Token the dashboard sends to the backend's gated /api/events SSE stream.
# Must equal the backend's MCP_TOKEN. NOTE: this value ships in the client bundle,
# so only use it for a LOCAL/private dashboard — do not deploy the dashboard
# publicly with a real token embedded (a separate read-only dashboard token is TODO).
NEXT_PUBLIC_DASHBOARD_TOKEN=

# Mode select. Omit or set false = DEMO mode: fully offline mock data, safe to
# deploy publicly (never connects to a backend). Set to true ONLY for a local
# dashboard wired to your real backend (then also set NEXT_PUBLIC_DASHBOARD_TOKEN).
NEXT_PUBLIC_LIVE_MODE=
